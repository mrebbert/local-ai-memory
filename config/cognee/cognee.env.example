# Cognee configuration. Copy to `cognee.env` and fill in real values.
# Mounted into the cognee container via `env_file`.

ENVIRONMENT="local"

# --- Auth: single-user mode (no tokens) ---
ENABLE_BACKEND_ACCESS_CONTROL=false
REQUIRE_AUTHENTICATION=false

# --- LLM: used for entity/relation extraction and recall phrasing ---
# Any LiteLLM-compatible provider works. A small, cheap model is enough for extraction.
LLM_PROVIDER="anthropic"
LLM_MODEL="claude-haiku-4-5"
LLM_API_KEY="<YOUR_LLM_API_KEY>"

# Local alternative (requires a GPU strong enough for reliable extraction):
# point the LLM at a local Ollama / OpenAI-compatible endpoint instead of the cloud.
# LLM_PROVIDER="ollama"
# LLM_MODEL="llama3.1:8b"
# LLM_ENDPOINT="http://ollama-cognee:11434/v1"
# LLM_API_KEY="ollama"   # placeholder; local endpoints usually ignore it

# --- Embeddings: local via Ollama ---
# IMPORTANT: the endpoint is /api/embed, NOT /api/embeddings.
EMBEDDING_PROVIDER="ollama"
EMBEDDING_MODEL="nomic-embed-text"
EMBEDDING_ENDPOINT="http://ollama-cognee:11434/api/embed"
EMBEDDING_DIMENSIONS=768
HUGGINGFACE_TOKENIZER="nomic-ai/nomic-embed-text-v1.5"

# --- Rate limiter: REQUIRED for CPU-only Ollama (single slot). ---
# Without it, bulk ingestion cascades into timeouts.
EMBEDDING_RATE_LIMIT_ENABLED=true
EMBEDDING_RATE_LIMIT_REQUESTS=30
EMBEDDING_RATE_LIMIT_INTERVAL=60

# --- Relational + vector store (mirror VECTOR_DB_* explicitly) ---
DB_PROVIDER="postgres"
DB_HOST="cognee-postgres"
DB_PORT=5432
DB_USERNAME="cognee"
DB_PASSWORD="<COGNEE_DB_PASSWORD>"
DB_NAME="cognee_db"
VECTOR_DB_PROVIDER="pgvector"
VECTOR_DB_HOST="cognee-postgres"
VECTOR_DB_PORT=5432
VECTOR_DB_USERNAME="cognee"
VECTOR_DB_PASSWORD="<COGNEE_DB_PASSWORD>"
VECTOR_DB_NAME="cognee_db"

# --- Graph store (file-based) ---
GRAPH_DATABASE_PROVIDER="kuzu"

HOST="0.0.0.0"
LOG_LEVEL="INFO"
DEBUG=false
CORS_ALLOWED_ORIGINS="*"
